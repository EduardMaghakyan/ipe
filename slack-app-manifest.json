{
  "_metadata": {
    "major_version": 2,
    "minor_version": 1
  },
  "display_information": {
    "name": "IPE - Claude Code",
    "description": "Stream Claude Code events and manage sessions from Slack",
    "background_color": "#1a1a2e"
  },
  "settings": {
    "socket_mode_enabled": true,
    "org_deploy_enabled": false,
    "interactivity": {
      "is_enabled": true
    }
  },
  "features": {
    "bot_user": {
      "display_name": "Claude Code",
      "always_online": true
    }
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "chat:write",
        "channels:read",
        "groups:read"
      ]
    }
  }
}